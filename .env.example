# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3001
DATABASE_URL=sqlite://agri-pay.db

# ── Bitcoin / Lightning ───────────────────────────────────────────────────────
BITCOIN_NETWORK=regtest          # mainnet | testnet | signet | regtest
LDK_DATA_DIR=./ldk-data
# Required for testnet/mainnet:
ESPLORA_URL=https://blockstream.info/testnet/api

# ── M-Pesa Daraja ─────────────────────────────────────────────────────────────
MPESA_ENV=sandbox                # sandbox | production
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=600998
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=Safaricom999!*!
# Production only: path to PEM public key extracted from Safaricom's production cert.
# Extract with: openssl x509 -pubkey -noout -in ProductionCertificate.cer > mpesa_prod_pubkey.pem
MPESA_CERT_PATH=

# ── Webhook callback URLs ─────────────────────────────────────────────────────
# BASE_URL must be publicly reachable so Safaricom can POST results back.
BASE_URL=http://localhost:3001
# If left unset, these are auto-generated as:
#   {BASE_URL}/api/webhooks/mpesa/{WEBHOOK_SECRET}/result (etc.)
# MPESA_RESULT_URL=
# MPESA_TIMEOUT_URL=

# ── FX Oracle ─────────────────────────────────────────────────────────────────
COINGECKO_API_URL=https://api.coingecko.com/api/v3
RATE_CACHE_SECONDS=60

# ── Security ──────────────────────────────────────────────────────────────────
# API key required in X-Api-Key header on all /api/* requests (except webhooks).
# Leave empty to disable auth (development / sandbox only).
API_KEY=

# Secret token embedded in M-Pesa callback URLs to authenticate Safaricom callbacks.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=dev-webhook-secret

# Comma-separated origins allowed by CORS. Use "*" to allow any (dev only).
ALLOWED_ORIGINS=http://localhost:5173

# ── Observability ─────────────────────────────────────────────────────────────
# "json" for structured production logs; "text" for human-readable dev logs.
LOG_FORMAT=text
RUST_LOG=agri_pay=debug,tower_http=debug
